---
import BaseLayout from "~/layouts/BaseLayout.astro";
import { getT, getLocalePrefix } from "~/i18n";

const locale = "en" as const;
const t = getT(locale);
const prefix = getLocalePrefix(locale);
const homeHref = prefix === "" ? "/" : `${prefix}/`;
const mailLink = `<a href="mailto:&#099;&#111;&#110;&#116;&#097;&#099;&#116;&#064;&#115;&#116;&#101;&#102;&#097;&#110;&#098;&#114;&#097;&#117;&#109;&#046;&#100;&#101;">&#099;&#111;&#110;&#116;&#097;&#099;&#116;&#064;&#115;&#116;&#101;&#102;&#097;&#110;&#098;&#114;&#097;&#117;&#109;&#046;&#100;&#101;</a>`;
---

<BaseLayout
  title={t.legal.impressum.title}
  description={t.legal.impressum.description}
  locale={locale}
>
  <main id="top" class="px-6 md:px-12 pt-32 md:pt-40 pb-20">
    <div class="max-w-3xl mx-auto mb-10">
      <a href={homeHref} class="back-link interactive">
        <span aria-hidden="true">&larr;</span>
        <span>{t.legal.backToOverview}</span>
      </a>
    </div>

    <article class="max-w-3xl mx-auto legal-body">
      <header class="mb-12">
        <div class="eyebrow mb-6">{t.legal.eyebrow}</div>
        <h1 class="legal-h1">{t.legal.impressum.h1}</h1>
      </header>

      <section>
        <h2>Service Provider</h2>
        <p>
          Stefan Braum<br/>
          Schlüchterner Straße 31<br/>
          36391 Sinntal<br/>
          Germany
        </p>
      </section>

      <section>
        <h2>Contact</h2>
        <p>
          Email: <Fragment set:html={mailLink} /><br/>
          Contact form: <a href="https://braum.me/mail" target="_blank" rel="noopener noreferrer">braum.me/mail</a>
        </p>
      </section>

      <section>
        <h2>Responsible for content per Section 18 (2) MStV</h2>
        <p>Stefan Braum (address as above)</p>
      </section>

      <section>
        <h2>Online Dispute Resolution (ODR)</h2>
        <p>
          The European Commission provides an online dispute resolution platform at
          <a href="https://ec.europa.eu/consumers/odr/" target="_blank" rel="noopener noreferrer">ec.europa.eu/consumers/odr/</a>.
          I am neither obligated nor willing to participate in a dispute resolution procedure before a consumer arbitration board.
        </p>
      </section>

      <section>
        <h2>Social Media Presence</h2>
        <ul>
          <li><a href="https://www.linkedin.com/in/stefanbraum/" target="_blank" rel="noopener noreferrer">LinkedIn - linkedin.com/in/stefanbraum</a></li>
          <li><a href="https://braum.me" target="_blank" rel="noopener noreferrer">braum.me - Linktree</a></li>
          <li><a href="https://github.com/braum-me" target="_blank" rel="noopener noreferrer">GitHub - github.com/braum-me</a></li>
        </ul>
      </section>

      <section>
        <h2>Liability and Intellectual Property</h2>
        <p>
          All content presented on this website - in particular texts, graphics, visualisations and analyses - is protected by the respective rights holders.
        </p>
        <p>
          Content is created with care; however, no guarantee is given for its currency, correctness or completeness. Please report errors or suggestions by email.
        </p>
        <p>
          References and links to external third-party websites lie outside my area of responsibility. The respective provider or operator is responsible for the content of the linked sites. Permanent monitoring of linked sites is not reasonable without concrete indications of a legal violation; on becoming aware of any legal violations, such links will be removed without delay.
        </p>
      </section>
    </article>
  </main>
</BaseLayout>

<style>
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(242, 239, 228, 0.55);
    text-decoration: none;
    transition: color 0.25s ease, transform 0.25s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .back-link:hover {
    color: var(--mint);
    transform: translateX(-4px);
  }

  .legal-h1 {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(2.25rem, 6vw, 4.5rem);
    line-height: 1.05;
    color: var(--cream);
    letter-spacing: -0.025em;
  }

  .legal-body section {
    margin-bottom: 2.4rem;
  }
  .legal-body h2 {
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 2.2vw, 1.5rem);
    font-weight: 500;
    color: var(--cream);
    letter-spacing: -0.012em;
    margin-bottom: 0.75rem;
    margin-top: 0.5rem;
  }
  .legal-body p {
    font-family: var(--font-body);
    color: rgba(242, 239, 228, 0.78);
    font-size: 1rem;
    line-height: 1.7;
    margin-bottom: 1rem;
  }
  .legal-body a {
    color: var(--mint);
    text-decoration: none;
    border-bottom: 1px solid rgba(0, 200, 150, 0.4);
    padding-bottom: 1px;
    transition: color 0.25s ease, border-color 0.25s ease;
  }
  .legal-body a:hover {
    color: var(--cream);
    border-bottom-color: var(--cream);
  }
  .legal-body ul {
    list-style: none;
    padding: 0;
    margin-bottom: 1rem;
  }
  .legal-body ul li {
    position: relative;
    padding-left: 1.25rem;
    color: rgba(242, 239, 228, 0.78);
    font-family: var(--font-body);
    line-height: 1.65;
    margin-bottom: 0.55rem;
  }
  .legal-body ul li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.7em;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--mint);
    opacity: 0.7;
  }
</style>
