---
export const prerender = true;

import BaseLayout from "~/layouts/BaseLayout.astro";
import Nav from "~/components/Nav.astro";
import Footer from "~/components/Footer.astro";
import { getT } from "~/i18n";

const locale = "en" as const;
const t = getT(locale);
---

<BaseLayout
  title={t.notFound.title}
  description={t.notFound.description}
  noindex={true}
  locale={locale}
>
  <Nav locale={locale} />
  <main id="top">
    <section class="relative px-6 md:px-12 pt-32 md:pt-40 pb-24 md:pb-32">
      <div class="max-w-4xl mx-auto text-center md:text-left">
        <div class="eyebrow mb-8">{t.notFound.eyebrow}</div>
        <h1 class="not-found-code" data-anim="section-title">404</h1>
        <p class="not-found-lede">{t.notFound.lede}</p>
        <p class="not-found-sub">{t.notFound.sub}</p>
        <div class="not-found-actions">
          <a href="/en/" class="not-found-link interactive">{t.notFound.home}</a>
          <span class="not-found-sep" aria-hidden="true">&middot;</span>
          <a href="/en/blog/" class="not-found-link interactive">{t.notFound.blog}</a>
        </div>
      </div>
    </section>
  </main>
  <Footer locale={locale} />
</BaseLayout>

<style>
  .not-found-code {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(96px, 18vw, 220px);
    color: var(--cream);
    letter-spacing: -0.04em;
    line-height: 0.95;
    margin-bottom: 24px;
    text-wrap: balance;
  }
  .not-found-lede {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(22px, 3vw, 36px);
    color: var(--cream);
    letter-spacing: -0.015em;
    line-height: 1.2;
    margin-bottom: 16px;
    max-width: 30ch;
  }
  .not-found-sub {
    font-family: var(--font-body);
    font-size: clamp(16px, 1.6vw, 18px);
    color: rgba(242, 239, 228, 0.7);
    line-height: 1.55;
    margin-bottom: 32px;
    max-width: 55ch;
  }
  .not-found-actions {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 14px;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .not-found-link {
    color: var(--mint);
    text-decoration: none;
    border-bottom: 1px solid rgba(0, 200, 150, 0.4);
    padding-bottom: 2px;
    transition: border-color 0.2s ease, color 0.2s ease;
  }
  .not-found-link:hover {
    color: var(--cream);
    border-bottom-color: var(--cream);
  }
  .not-found-sep {
    color: rgba(242, 239, 228, 0.25);
  }
</style>
