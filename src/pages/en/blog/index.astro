---
export const prerender = true;

import BaseLayout from "~/layouts/BaseLayout.astro";
import Nav from "~/components/Nav.astro";
import Footer from "~/components/Footer.astro";
import { getCollection, type CollectionEntry } from "astro:content";
import { env } from "~/lib/env.ts";
import { getT } from "~/i18n";

const locale = "en" as const;
const t = getT(locale);

type Post = CollectionEntry<"blog">;
const allPosts = (await getCollection("blog")) as Post[];
const posts: Post[] = allPosts
  .filter((p: Post) => !p.data.draft)
  .sort((a: Post, b: Post) => b.data.date.valueOf() - a.data.date.valueOf());

const dateFmt = new Intl.DateTimeFormat(t.intlLocale, {
  day: "2-digit",
  month: "short",
  year: "numeric",
});

const allTags = Array.from(
  new Set(posts.flatMap((p) => p.data.tags)),
).sort((a, b) => a.localeCompare(b));

const siteUrl =
  env("PUBLIC_SITE_URL") ?? Astro.site?.toString() ?? "https://stefanbraum.de";

const blogJsonLd = {
  "@context": "https://schema.org",
  "@type": "Blog",
  name: "Stefan Braum - Writing",
  description: t.writing.listingDescription,
  url: new URL("/en/blog/", siteUrl).toString(),
  inLanguage: "en-US",
  author: {
    "@type": "Person",
    name: "Stefan Braum",
    url: siteUrl,
  },
  blogPost: posts.map((p) => ({
    "@type": "BlogPosting",
    headline: p.data.title,
    description: p.data.excerpt,
    datePublished: p.data.date.toISOString(),
    dateModified: p.data.date.toISOString(),
    url: new URL(`/blog/${p.id}/`, siteUrl).toString(),
    keywords: p.data.tags.join(", "),
    inLanguage: "de-DE",
    author: {
      "@type": "Person",
      name: "Stefan Braum",
      url: siteUrl,
    },
  })),
};
---

<BaseLayout
  title={t.writing.listingTitle}
  description={t.writing.listingDescription}
  locale={locale}
>
  <Nav locale={locale} />
  <main id="top">
    <section class="relative px-6 md:px-12 pt-32 md:pt-40 pb-24 md:pb-32">
      <div class="max-w-5xl mx-auto">
        <div class="eyebrow mb-8">{t.writing.eyebrow}</div>
        <h1 class="heading-giant text-cream mb-10" data-anim="section-title">
          {t.writing.listingHeadline}
        </h1>
        <p class="font-body text-lg md:text-xl text-cream/70 leading-[1.55] max-w-[58ch] mb-8">
          {t.writing.listingSubline}
        </p>

        <div class="lang-notice" role="note">
          {t.writing.notice}
        </div>

        {allTags.length > 0 && (
          <nav class="tag-filter" aria-label={t.writing.blogIndexAria}>
            <button
              type="button"
              class="tag-pill is-active"
              data-tag-filter="all"
              aria-pressed="true"
            >
              {t.writing.filterAll}
            </button>
            {allTags.map((tag) => (
              <button
                type="button"
                class="tag-pill"
                data-tag-filter={tag}
                aria-pressed="false"
              >
                {tag}
              </button>
            ))}
          </nav>
        )}

        <ul class="blog-list" id="blog-list">
          {posts.map((post: Post) => (
            <li
              class="blog-item"
              data-tags={post.data.tags.join(",")}
            >
              <a href={`/blog/${post.id}/`} class="blog-link interactive" lang="de" hreflang="de">
                <div class="blog-meta">
                  <time datetime={post.data.date.toISOString()}>
                    {dateFmt.format(post.data.date)}
                  </time>
                  {post.data.readingTime && (
                    <>
                      <span class="blog-sep" aria-hidden="true">&middot;</span>
                      <span>{post.data.readingTime}</span>
                    </>
                  )}
                  <span class="blog-sep" aria-hidden="true">&middot;</span>
                  <span class="blog-lang-tag">DE</span>
                </div>
                <h2 class="blog-title">{post.data.title}</h2>
                <p class="blog-excerpt">{post.data.excerpt}</p>
                {post.data.tags.length > 0 && (
                  <div class="blog-tags">
                    {post.data.tags.map((tag: string) => (
                      <span class="blog-tag">{tag}</span>
                    ))}
                  </div>
                )}
              </a>
            </li>
          ))}
        </ul>

        <p class="blog-empty" id="blog-empty" hidden>
          {t.writing.filterEmpty}
        </p>

        {posts.length === 0 && (
          <p class="font-body text-cream/55">{t.writing.empty}</p>
        )}
      </div>
    </section>
  </main>
  <Footer locale={locale} />
  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(blogJsonLd)}
  />
</BaseLayout>

<script>
  const pills = document.querySelectorAll<HTMLButtonElement>("[data-tag-filter]");
  const items = document.querySelectorAll<HTMLLIElement>("#blog-list .blog-item");
  const empty = document.getElementById("blog-empty");

  function applyFilter(tag: string) {
    let visible = 0;
    items.forEach((item) => {
      const tags = (item.dataset.tags ?? "").split(",").map((s) => s.trim());
      const match = tag === "all" || tags.includes(tag);
      item.hidden = !match;
      if (match) visible++;
    });

    pills.forEach((p) => {
      const isActive = (p.dataset.tagFilter ?? "all") === tag;
      p.classList.toggle("is-active", isActive);
      p.setAttribute("aria-pressed", isActive ? "true" : "false");
    });

    if (empty) empty.hidden = visible !== 0;

    const url = new URL(window.location.href);
    if (tag === "all") {
      url.searchParams.delete("tag");
    } else {
      url.searchParams.set("tag", tag);
    }
    history.replaceState({}, "", url.toString());
  }

  pills.forEach((pill) => {
    pill.addEventListener("click", () => {
      const tag = pill.dataset.tagFilter ?? "all";
      applyFilter(tag);
    });
  });

  const urlTag = new URLSearchParams(window.location.search).get("tag");
  if (urlTag) applyFilter(urlTag);
</script>

<style>
  .lang-notice {
    font-family: var(--font-mono);
    font-size: 11.5px;
    letter-spacing: 0.08em;
    color: rgba(242, 239, 228, 0.55);
    background: rgba(0, 200, 150, 0.06);
    border: 1px solid rgba(0, 200, 150, 0.18);
    padding: 12px 16px;
    border-radius: 4px;
    margin-bottom: 32px;
    max-width: 65ch;
    line-height: 1.55;
  }
  .blog-lang-tag {
    color: var(--mint);
    font-weight: 500;
  }
  .tag-filter {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 32px;
    padding-bottom: 24px;
    border-bottom: 1px solid rgba(242, 239, 228, 0.06);
  }
  .tag-pill {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(242, 239, 228, 0.55);
    background: transparent;
    border: 1px solid rgba(242, 239, 228, 0.15);
    border-radius: 999px;
    padding: 6px 12px;
    line-height: 1.4;
    cursor: pointer;
    transition:
      color 0.2s ease,
      border-color 0.2s ease,
      background 0.2s ease;
  }
  .tag-pill:hover {
    color: var(--mint);
    border-color: rgba(0, 200, 150, 0.4);
  }
  .tag-pill.is-active {
    color: var(--forest-deepest, #051e16);
    background: var(--mint);
    border-color: var(--mint);
  }
  .blog-empty {
    font-family: var(--font-body);
    color: rgba(242, 239, 228, 0.55);
    margin-top: 28px;
  }
  .blog-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
  }
  .blog-item {
    border-top: 1px solid rgba(242, 239, 228, 0.08);
  }
  .blog-item:last-child {
    border-bottom: 1px solid rgba(242, 239, 228, 0.08);
  }
  .blog-link {
    display: block;
    padding: 28px 0;
    text-decoration: none;
    color: var(--cream);
    transition: padding 0.3s ease;
  }
  .blog-link:hover {
    padding-left: 8px;
  }
  .blog-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: rgba(242, 239, 228, 0.4);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 10px;
  }
  .blog-sep {
    color: rgba(242, 239, 228, 0.2);
  }
  .blog-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(20px, 2.4vw, 28px);
    color: var(--cream);
    letter-spacing: -0.015em;
    line-height: 1.25;
    margin-bottom: 8px;
    transition: color 0.25s ease;
  }
  .blog-link:hover .blog-title {
    color: var(--mint);
  }
  .blog-excerpt {
    font-family: var(--font-body);
    font-size: 15px;
    color: rgba(242, 239, 228, 0.65);
    line-height: 1.6;
    max-width: 65ch;
  }
  .blog-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 14px;
  }
  .blog-tag {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(0, 200, 150, 0.7);
    border: 1px solid rgba(0, 200, 150, 0.25);
    border-radius: 999px;
    padding: 2px 8px;
    line-height: 1.4;
  }
</style>
