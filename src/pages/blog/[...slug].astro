---
export const prerender = true;

import BaseLayout from "~/layouts/BaseLayout.astro";
import Nav from "~/components/Nav.astro";
import Footer from "~/components/Footer.astro";
import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { env } from "~/lib/env.ts";
import { cases } from "~/data/cases.ts";
import { getT } from "~/i18n";

const t = getT("de");

type Post = CollectionEntry<"blog">;

export async function getStaticPaths() {
  const posts = (await getCollection("blog")) as Post[];
  return posts.map((post: Post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props as { post: Post };
const { Content } = await render(post);

// Reverse-Lookup: gibt es einen Case der diesen Blog-Post als blogSlug referenziert?
const linkedCase = cases.find((c) => c.blogSlug === post.id);

const dateFmt = new Intl.DateTimeFormat("de-DE", {
  day: "2-digit",
  month: "long",
  year: "numeric",
});

const dateShortFmt = new Intl.DateTimeFormat("de-DE", {
  day: "2-digit",
  month: "short",
  year: "numeric",
});

// Related Posts: max 3 mit gemeinsamen Tags, Fallback latest 3
const allPosts = (await getCollection("blog")) as Post[];
const otherPosts = allPosts
  .filter((p) => !p.data.draft && p.id !== post.id)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const currentTags = new Set(post.data.tags);
const scored = otherPosts
  .map((p) => ({
    post: p,
    overlap: p.data.tags.filter((t: string) => currentTags.has(t)).length,
  }))
  .sort((a, b) => {
    if (b.overlap !== a.overlap) return b.overlap - a.overlap;
    return b.post.data.date.valueOf() - a.post.data.date.valueOf();
  });

const withOverlap = scored.filter((s) => s.overlap > 0).slice(0, 3);
const related =
  withOverlap.length > 0
    ? withOverlap.map((s) => s.post)
    : otherPosts.slice(0, 3);

const siteUrl =
  env("PUBLIC_SITE_URL") ?? Astro.site?.toString() ?? "https://stefanbraum.de";
const postUrl = new URL(`/blog/${post.id}/`, siteUrl).toString();

const blogPostingJsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.data.title,
  description: post.data.excerpt,
  datePublished: post.data.date.toISOString(),
  dateModified: post.data.date.toISOString(),
  inLanguage: "de-DE",
  keywords: post.data.tags.join(", "),
  author: {
    "@type": "Person",
    name: "Stefan Braum",
    url: siteUrl,
  },
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": postUrl,
  },
  url: postUrl,
};
---

<BaseLayout
  title={`${post.data.title} · Stefan Braum`}
  description={post.data.excerpt}
  locale="de"
>
  <Nav locale="de" />
  <div class="reading-progress" id="reading-progress" aria-hidden="true"></div>
  <main id="top">
    <article class="relative px-6 md:px-12 pt-32 md:pt-40 pb-24 md:pb-32">
      <div class="max-w-3xl mx-auto">
        <a href="/blog/" class="blog-back interactive">← Schreiben</a>

        <header class="blog-header">
          <div class="blog-meta">
            <time datetime={post.data.date.toISOString()}>
              {dateFmt.format(post.data.date)}
            </time>
            {post.data.readingTime && (
              <>
                <span class="blog-sep" aria-hidden="true">·</span>
                <span>{post.data.readingTime}</span>
              </>
            )}
          </div>
          <h1 class="blog-h1" data-anim="section-title">{post.data.title}</h1>
          <p class="blog-lede">{post.data.excerpt}</p>
          {linkedCase && (
            <a href={`/#case-${linkedCase.id}`} class="blog-case-link interactive">
              <span class="blog-case-link-tag">{t.cases.fromPortfolio}</span>
              <span class="blog-case-link-title">{linkedCase.title}</span>
              <span class="blog-case-link-arrow" aria-hidden="true">&rarr;</span>
            </a>
          )}
        </header>

        <div class="blog-content">
          <Content />
        </div>

        {post.data.tags.length > 0 && (
          <footer class="blog-footer">
            <div class="blog-tags">
              {post.data.tags.map((t: string) => (
                <span class="blog-tag">{t}</span>
              ))}
            </div>
          </footer>
        )}

        {related.length > 0 && (
          <section class="related" aria-labelledby="related-heading">
            <h2 id="related-heading" class="related-heading">Weiterlesen</h2>
            <ul class="related-list">
              {related.map((p) => (
                <li class="related-item">
                  <a href={`/blog/${p.id}/`} class="related-link interactive">
                    <div class="blog-meta">
                      <time datetime={p.data.date.toISOString()}>
                        {dateShortFmt.format(p.data.date)}
                      </time>
                      {p.data.readingTime && (
                        <>
                          <span class="blog-sep" aria-hidden="true">·</span>
                          <span>{p.data.readingTime}</span>
                        </>
                      )}
                    </div>
                    <h3 class="related-title">{p.data.title}</h3>
                    <p class="related-excerpt">{p.data.excerpt}</p>
                    {p.data.tags.length > 0 && (
                      <div class="blog-tags">
                        {p.data.tags.map((t: string) => (
                          <span class="blog-tag">{t}</span>
                        ))}
                      </div>
                    )}
                  </a>
                </li>
              ))}
            </ul>
          </section>
        )}
      </div>
    </article>
  </main>
  <Footer locale="de" />

  <!-- Lightbox overlay for blog-content images -->
  <div class="lightbox" id="lightbox" hidden role="dialog" aria-modal="true" aria-label="Bildvorschau">
    <button type="button" class="lightbox-close interactive" id="lightbox-close" aria-label="Schliessen">
      <span aria-hidden="true">&times;</span>
    </button>
    <figure class="lightbox-figure">
      <img class="lightbox-img" id="lightbox-img" alt="" />
      <figcaption class="lightbox-caption" id="lightbox-caption" hidden></figcaption>
    </figure>
  </div>

  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(blogPostingJsonLd)}
  />
</BaseLayout>

<script>
  const bar = document.getElementById("reading-progress");
  if (bar) {
    const update = () => {
      const scrollTop = window.scrollY;
      const docHeight =
        document.documentElement.scrollHeight - window.innerHeight;
      const progress = docHeight > 0 ? scrollTop / docHeight : 0;
      bar.style.transform = `scaleX(${Math.min(1, Math.max(0, progress))})`;
    };
    window.addEventListener("scroll", update, { passive: true });
    window.addEventListener("resize", update, { passive: true });
    update();
  }

  // Lightbox: Click auf Blog-Content-Bilder öffnet Vollbild-Overlay
  const lightbox = document.getElementById("lightbox") as HTMLElement | null;
  const lightboxImg = document.getElementById("lightbox-img") as HTMLImageElement | null;
  const lightboxCaption = document.getElementById("lightbox-caption") as HTMLElement | null;
  const lightboxClose = document.getElementById("lightbox-close");

  if (lightbox && lightboxImg && lightboxCaption) {
    const open = (src: string, alt: string, caption: string | null) => {
      lightboxImg.src = src;
      lightboxImg.alt = alt;
      if (caption) {
        lightboxCaption.textContent = caption;
        lightboxCaption.removeAttribute("hidden");
      } else {
        lightboxCaption.textContent = "";
        lightboxCaption.setAttribute("hidden", "");
      }
      lightbox.removeAttribute("hidden");
      requestAnimationFrame(() => lightbox.classList.add("is-open"));
      document.body.style.overflow = "hidden";
    };

    const close = () => {
      lightbox.classList.remove("is-open");
      document.body.style.overflow = "";
      window.setTimeout(() => {
        lightbox.setAttribute("hidden", "");
        if (lightboxImg) lightboxImg.src = "";
      }, 220);
    };

    document.querySelectorAll<HTMLImageElement>(".blog-content img").forEach((img) => {
      img.style.cursor = "zoom-in";
      img.addEventListener("click", () => {
        const figure = img.closest("figure");
        const cap = figure?.querySelector("figcaption")?.textContent ?? null;
        open(img.currentSrc || img.src, img.alt, cap);
      });
    });

    lightboxClose?.addEventListener("click", close);
    lightbox.addEventListener("click", (e) => {
      if (e.target === lightbox) close();
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !lightbox.hasAttribute("hidden")) close();
    });
  }
</script>

<style>
  .reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--mint);
    transform-origin: left center;
    transform: scaleX(0);
    z-index: 100;
    box-shadow: 0 0 8px rgba(0, 200, 150, 0.5);
    pointer-events: none;
    will-change: transform;
  }
  @media (prefers-reduced-motion: reduce) {
    .reading-progress {
      transition: none;
    }
  }

  .blog-back {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(242, 239, 228, 0.55);
    margin-bottom: 32px;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .blog-back:hover {
    color: var(--mint);
  }
  .blog-header {
    margin-bottom: 56px;
  }
  .blog-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: rgba(242, 239, 228, 0.4);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 14px;
  }
  .blog-sep {
    color: rgba(242, 239, 228, 0.2);
  }
  .blog-h1 {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(28px, 4.5vw, 48px);
    color: var(--cream);
    letter-spacing: -0.02em;
    line-height: 1.12;
    margin-bottom: 18px;
    text-wrap: balance;
  }
  .blog-lede {
    font-family: var(--font-body);
    font-size: clamp(17px, 1.7vw, 20px);
    color: rgba(242, 239, 228, 0.75);
    line-height: 1.55;
    max-width: 60ch;
  }

  /* Cross-link: dieser Post -> Portfolio-Case (wenn blogSlug gemappt) */
  .blog-case-link {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-top: 24px;
    padding: 9px 16px;
    border: 1px solid rgba(0, 200, 150, 0.3);
    border-radius: 999px;
    background: rgba(0, 200, 150, 0.06);
    color: var(--cream);
    text-decoration: none;
    transition: background 0.2s ease, border-color 0.2s ease, transform 0.25s cubic-bezier(0.2, 0.8, 0.2, 1);
    max-width: 100%;
  }
  .blog-case-link:hover {
    background: rgba(0, 200, 150, 0.14);
    border-color: var(--mint);
    transform: translateX(2px);
  }
  .blog-case-link-tag {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--mint);
    flex-shrink: 0;
  }
  .blog-case-link-title {
    font-family: var(--font-body);
    font-size: 14px;
    color: rgba(242, 239, 228, 0.85);
    line-height: 1.3;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .blog-case-link-arrow {
    color: var(--mint);
    flex-shrink: 0;
    transition: transform 0.25s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .blog-case-link:hover .blog-case-link-arrow {
    transform: translateX(2px);
  }

  .blog-content {
    font-family: var(--font-body);
    font-size: 16.5px;
    line-height: 1.72;
    color: rgba(242, 239, 228, 0.85);
    max-width: 65ch;
  }
  .blog-content :global(h2) {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(22px, 2.4vw, 28px);
    color: var(--cream);
    letter-spacing: -0.012em;
    line-height: 1.2;
    margin-top: 56px;
    margin-bottom: 18px;
  }
  .blog-content :global(h3) {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 19px;
    color: var(--cream);
    letter-spacing: -0.005em;
    line-height: 1.3;
    margin-top: 36px;
    margin-bottom: 12px;
  }
  .blog-content :global(p) {
    margin-bottom: 18px;
  }
  .blog-content :global(p:last-child) {
    margin-bottom: 0;
  }
  .blog-content :global(a) {
    color: var(--mint);
    text-decoration: none;
    border-bottom: 1px solid rgba(0, 200, 150, 0.4);
    transition: border-color 0.2s ease;
  }
  .blog-content :global(a:hover) {
    border-bottom-color: var(--mint);
  }
  .blog-content :global(strong) {
    color: var(--cream);
    font-weight: 600;
  }
  .blog-content :global(ul),
  .blog-content :global(ol) {
    margin-bottom: 22px;
    padding-left: 22px;
  }
  .blog-content :global(li) {
    margin-bottom: 8px;
  }
  .blog-content :global(li::marker) {
    color: var(--mint);
  }
  .blog-content :global(blockquote) {
    border-left: 2px solid var(--mint);
    padding-left: 18px;
    margin: 28px 0;
    color: rgba(242, 239, 228, 0.7);
    font-style: italic;
  }
  .blog-content :global(code) {
    font-family: var(--font-mono);
    font-size: 0.92em;
    background: rgba(0, 200, 150, 0.08);
    border: 1px solid rgba(0, 200, 150, 0.15);
    border-radius: 3px;
    padding: 1px 6px;
    color: var(--mint);
  }
  .blog-content :global(pre) {
    font-family: var(--font-mono);
    font-size: 13.5px;
    background: rgba(5, 30, 22, 0.6);
    border: 1px solid rgba(242, 239, 228, 0.08);
    border-radius: 4px;
    padding: 16px 20px;
    overflow-x: auto;
    margin: 24px 0;
  }
  .blog-content :global(pre code) {
    background: transparent;
    border: none;
    padding: 0;
    color: var(--cream);
  }
  .blog-content :global(.contact-mail) {
    font-family: var(--font-mono);
    color: var(--mint);
  }

  .blog-content :global(img) {
    display: block;
    max-width: 100%;
    height: auto;
    margin: 32px auto;
    border-radius: 6px;
    border: 1px solid rgba(242, 239, 228, 0.08);
    background: rgba(5, 30, 22, 0.4);
    box-shadow:
      0 20px 40px -20px rgba(0, 0, 0, 0.55),
      0 0 0 1px rgba(0, 200, 150, 0.04);
  }
  .blog-content :global(img + em),
  .blog-content :global(figure figcaption) {
    display: block;
    text-align: center;
    margin-top: 10px;
    margin-bottom: 0;
    font-family: var(--font-mono);
    font-size: 11.5px;
    letter-spacing: 0.06em;
    color: rgba(242, 239, 228, 0.45);
  }

  /* Side-by-side compare-grid (z.B. für Modell-Vergleiche) */
  .blog-content :global(.compare-grid) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
    margin: 32px 0;
  }
  @media (max-width: 720px) {
    .blog-content :global(.compare-grid) {
      grid-template-columns: 1fr;
      gap: 24px;
    }
  }
  .blog-content :global(.compare-grid figure) {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .blog-content :global(.compare-grid img) {
    margin: 0;
  }
  .blog-content :global(.compare-grid figcaption) {
    margin-top: 10px;
  }

  .blog-footer {
    margin-top: 64px;
    padding-top: 28px;
    border-top: 1px solid rgba(242, 239, 228, 0.08);
  }
  .blog-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .blog-tag {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(0, 200, 150, 0.7);
    border: 1px solid rgba(0, 200, 150, 0.25);
    border-radius: 999px;
    padding: 2px 8px;
    line-height: 1.4;
  }

  .related {
    margin-top: 80px;
    padding-top: 40px;
    border-top: 1px solid rgba(242, 239, 228, 0.08);
  }
  .related-heading {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(242, 239, 228, 0.5);
    margin-bottom: 24px;
  }
  .related-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
  }
  .related-item {
    border-top: 1px solid rgba(242, 239, 228, 0.08);
  }
  .related-item:last-child {
    border-bottom: 1px solid rgba(242, 239, 228, 0.08);
  }
  .related-link {
    display: block;
    padding: 24px 0;
    text-decoration: none;
    color: var(--cream);
    transition: padding 0.3s ease;
  }
  .related-link:hover {
    padding-left: 8px;
  }
  .related-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(18px, 2vw, 22px);
    color: var(--cream);
    letter-spacing: -0.012em;
    line-height: 1.25;
    margin-top: 6px;
    margin-bottom: 8px;
    transition: color 0.25s ease;
  }
  .related-link:hover .related-title {
    color: var(--mint);
  }
  .related-excerpt {
    font-family: var(--font-body);
    font-size: 14.5px;
    color: rgba(242, 239, 228, 0.6);
    line-height: 1.55;
    max-width: 65ch;
    margin-bottom: 12px;
  }

  /* Lightbox / Image Preview */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 500;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 32px;
    background: rgba(2, 8, 6, 0.86);
    backdrop-filter: blur(12px) saturate(140%);
    -webkit-backdrop-filter: blur(12px) saturate(140%);
    opacity: 0;
    transition: opacity 0.22s ease;
    cursor: zoom-out;
  }
  .lightbox[hidden] {
    display: none;
  }
  .lightbox.is-open {
    opacity: 1;
  }
  .lightbox-figure {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
    align-items: center;
    max-width: min(1400px, 100%);
    max-height: 100%;
    cursor: default;
  }
  .lightbox-img {
    display: block;
    max-width: 100%;
    max-height: calc(100vh - 140px);
    object-fit: contain;
    border-radius: 6px;
    border: 1px solid rgba(0, 200, 150, 0.18);
    box-shadow:
      0 30px 80px -20px rgba(0, 0, 0, 0.7),
      0 0 0 1px rgba(0, 200, 150, 0.04);
    transform: scale(0.96);
    transition: transform 0.22s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .lightbox.is-open .lightbox-img {
    transform: scale(1);
  }
  .lightbox-caption {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.06em;
    color: rgba(242, 239, 228, 0.7);
    text-align: center;
    max-width: 60ch;
  }
  .lightbox-close {
    position: absolute;
    top: 20px;
    right: 24px;
    width: 40px;
    height: 40px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgba(5, 30, 22, 0.6);
    border: 1px solid rgba(242, 239, 228, 0.2);
    border-radius: 50%;
    color: var(--cream);
    font-size: 22px;
    font-weight: 300;
    line-height: 1;
    cursor: pointer;
    transition: border-color 0.2s ease, color 0.2s ease, background 0.2s ease;
  }
  .lightbox-close:hover {
    border-color: var(--mint);
    color: var(--mint);
    background: rgba(5, 30, 22, 0.85);
  }
  @media (prefers-reduced-motion: reduce) {
    .lightbox,
    .lightbox-img {
      transition: none;
    }
  }
</style>
