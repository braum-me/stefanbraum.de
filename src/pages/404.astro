---
export const prerender = true;

import BaseLayout from "~/layouts/BaseLayout.astro";
import Nav from "~/components/Nav.astro";
import Footer from "~/components/Footer.astro";
---

<BaseLayout
  title="404 - Nicht gefunden - Stefan Braum"
  description="Diese Seite gibt es nicht (mehr)."
  noindex={true}
  locale="de"
>
  <Nav locale="de" />
  <main id="top">
    <section class="relative px-6 md:px-12 pt-32 md:pt-40 pb-24 md:pb-32">
      <div class="max-w-4xl mx-auto text-center md:text-left">
        <div class="eyebrow mb-8">Stefan Braum · Nicht gefunden</div>
        <h1 class="not-found-code" data-anim="section-title">404</h1>
        <p class="not-found-lede">Diese Seite gibt es nicht (mehr).</p>
        <p class="not-found-sub">
          Vielleicht ein alter Link, vielleicht ein Tippfehler. Hier geht es weiter:
        </p>
        <div class="not-found-actions">
          <a href="/" class="not-found-link interactive">Zur Startseite</a>
          <span class="not-found-sep" aria-hidden="true">·</span>
          <a href="/blog/" class="not-found-link interactive">Zum Blog</a>
        </div>
      </div>
    </section>
  </main>
  <Footer locale="de" />
</BaseLayout>

<style>
  .not-found-code {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(96px, 18vw, 220px);
    color: var(--cream);
    letter-spacing: -0.04em;
    line-height: 0.95;
    margin-bottom: 24px;
    text-wrap: balance;
  }
  .not-found-lede {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(22px, 3vw, 36px);
    color: var(--cream);
    letter-spacing: -0.015em;
    line-height: 1.2;
    margin-bottom: 16px;
    max-width: 30ch;
  }
  .not-found-sub {
    font-family: var(--font-body);
    font-size: clamp(16px, 1.6vw, 18px);
    color: rgba(242, 239, 228, 0.7);
    line-height: 1.55;
    margin-bottom: 32px;
    max-width: 55ch;
  }
  .not-found-actions {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 14px;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .not-found-link {
    color: var(--mint);
    text-decoration: none;
    border-bottom: 1px solid rgba(0, 200, 150, 0.4);
    padding-bottom: 2px;
    transition: border-color 0.2s ease, color 0.2s ease;
  }
  .not-found-link:hover {
    color: var(--cream);
    border-bottom-color: var(--cream);
  }
  .not-found-sep {
    color: rgba(242, 239, 228, 0.25);
  }
</style>
