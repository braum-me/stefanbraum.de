---
import { siteMeta } from "~/data/meta.ts";
import { getT, type Locale } from "~/i18n";

interface Props {
  locale?: Locale;
}
const { locale = "de" } = Astro.props;
const t = getT(locale);

const { mailUrl, links } = siteMeta;
---

<section id="kontakt" class="relative px-6 md:px-12 py-32 md:py-48">
  <div class="max-w-6xl mx-auto relative">
    <div class="eyebrow mb-10 reveal-elem">{t.contact.eyebrow}</div>

    <h2 class="heading-giant text-cream max-w-4xl mb-10 reveal-elem" data-anim="section-title">
      {t.contact.headline}
    </h2>

    <p class="font-body text-lg md:text-xl text-cream/70 leading-[1.55] max-w-3xl mb-16 md:mb-24 reveal-elem" id="kontakt-sub">
      {t.contact.subline}
    </p>

    <div class="grid md:grid-cols-3 gap-5 reveal-stagger">
      <a
        href={mailUrl}
        data-route="direct"
        id="route-direct"
        class="card-matte card-beam tilt interactive p-8 flex flex-col"
      >
        <div class="kicker text-mint mb-6">{t.contact.direct.kicker}</div>
        <h3 class="font-display text-xl md:text-2xl font-medium text-cream tracking-tight mb-4">
          {t.contact.direct.title}
        </h3>
        <p class="font-body text-[14.5px] text-cream/65 leading-[1.6] mb-8 flex-grow">
          {t.contact.direct.body}
        </p>
        <span class="kicker text-cream/50 inline-flex items-center gap-2">
          {t.contact.direct.cta}
          <span class="text-mint">&rarr;</span>
        </span>
      </a>

      <a
        href={links.linkedin}
        class="card-matte card-beam tilt interactive p-8 flex flex-col"
      >
        <div class="kicker text-mint mb-6">{t.contact.network.kicker}</div>
        <h3 class="font-display text-xl md:text-2xl font-medium text-cream tracking-tight mb-4">
          {t.contact.network.title}
        </h3>
        <p class="font-body text-[14.5px] text-cream/65 leading-[1.6] mb-8 flex-grow">
          {t.contact.network.body}
        </p>
        <span class="kicker text-cream/50 inline-flex items-center gap-2">
          {t.contact.network.cta}
          <span class="text-mint">&rarr;</span>
        </span>
      </a>

      <a
        href={links.me}
        class="card-matte card-beam tilt interactive p-8 flex flex-col"
      >
        <div class="kicker text-mint mb-6">{t.contact.more.kicker}</div>
        <h3 class="font-display text-xl md:text-2xl font-medium text-cream tracking-tight mb-4">
          {t.contact.more.title}
        </h3>
        <p class="font-body text-[14.5px] text-cream/65 leading-[1.6] mb-8 flex-grow">
          {t.contact.more.body}
        </p>
        <span class="kicker text-cream/50 inline-flex items-center gap-2">
          {t.contact.more.cta}
          <span class="text-mint">&rarr;</span>
        </span>
      </a>
    </div>
  </div>

  <script>
    // URL-Param focus → highlight direct-card
    const params = new URLSearchParams(window.location.search);
    const focus = params.get("focus");
    if (focus === "consulting") {
      const card = document.getElementById("route-direct");
      card?.classList.add("outline", "outline-2", "outline-mint");
      // Auto-scroll to contact if landed with ?focus=consulting
      setTimeout(() => {
        const el = document.getElementById("kontakt");
        el?.scrollIntoView({ behavior: "smooth", block: "start" });
      }, 600);
    }
  </script>
</section>
