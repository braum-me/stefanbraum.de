---
import { getT, type Locale } from "~/i18n";

interface Props {
  locale?: Locale;
}
const { locale = "de" } = Astro.props;
const t = getT(locale);
---

<section class="relative px-6 md:px-12 pt-24 md:pt-32 pb-20 md:pb-28 overflow-hidden" data-anim-group="hero">
  <div class="max-w-7xl mx-auto w-full relative">
    <div class="eyebrow" data-anim="eyebrow">{t.hero.eyebrow}</div>

    <div class="grid lg:grid-cols-[1.35fr_1fr] gap-12 lg:gap-20 items-center mt-10 md:mt-14">
      <!-- Left: content -->
      <div class="min-w-0 w-full order-2 lg:order-1">
        <h1 class="heading-hero text-cream max-w-4xl" data-anim="hero-title">
          {t.hero.headlinePart1}
          <span class="text-cream/55 block">{t.hero.headlinePart2}</span>
        </h1>

        <p
          class="font-body text-lg md:text-xl text-cream/75 mt-8 md:mt-10 max-w-2xl leading-[1.55]"
          data-anim="sub"
          data-sub-default={t.hero.sublineDefault}
          data-sub-consulting={t.hero.sublineConsulting}
          id="hero-sub"
        >
          {t.hero.sublineDefault}
        </p>

        <div class="mt-10 md:mt-12 flex flex-wrap items-center gap-3" data-anim="cta">
          <a href="#kontakt" class="btn-primary-mint interactive">
            {t.hero.ctaPrimary}
            <span>&rarr;</span>
          </a>
          <a href="#portfolio" class="btn-outline interactive">
            {t.hero.ctaSecondary}
            <span class="text-mint">&darr;</span>
          </a>
        </div>
      </div>

      <!-- Right: portrait -->
      <div class="order-1 lg:order-2 w-full" data-anim="portrait">
        <figure class="hero-portrait">
          <div class="hero-portrait-frame">
            <img
              src="/portrait.webp"
              alt={t.hero.portraitAlt}
              width="750"
              height="1000"
              loading="eager"
              fetchpriority="high"
              class="hero-portrait-img"
            />
            <div class="hero-portrait-fade" aria-hidden="true"></div>
            <div class="hero-portrait-grain" aria-hidden="true"></div>
            <span class="hero-portrait-accent" aria-hidden="true"></span>
          </div>
          <figcaption class="hero-portrait-caption">
            <span class="hero-portrait-caption-name">{t.hero.portraitName}</span>
            <span class="hero-portrait-caption-sep" aria-hidden="true">&middot;</span>
            <span class="hero-portrait-caption-role">{t.hero.portraitLocation}</span>
          </figcaption>
        </figure>
      </div>
    </div>
  </div>

  <script>
    // URL param swap (consulting only)
    const params = new URLSearchParams(window.location.search);
    const focus = params.get("focus");
    if (focus === "consulting") {
      const sub = document.getElementById("hero-sub");
      if (sub) {
        const text = sub.dataset.subConsulting;
        if (text) sub.textContent = text;
      }
    }
  </script>

  <style>
    .hero-portrait {
      max-width: 380px;
      width: 100%;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      gap: 16px;
    }
    @media (min-width: 1024px) {
      .hero-portrait {
        margin-left: auto;
        margin-right: 0;
        max-width: 420px;
      }
    }

    .hero-portrait-frame {
      position: relative;
      aspect-ratio: 3 / 4;
      width: 100%;
      border-radius: 4px;
      overflow: hidden;
      background: linear-gradient(160deg, #0d3d2e 0%, #051e16 65%, #020806 100%);
      box-shadow:
        0 30px 70px -25px rgba(0, 0, 0, 0.7),
        0 0 60px -20px rgba(0, 200, 150, 0.18),
        inset 0 0 0 1px rgba(242, 239, 228, 0.08);
      isolation: isolate;
    }

    /* Subtle Mint-Akzent: dünne Linie unten, fade-out zur Seite */
    .hero-portrait-accent {
      position: absolute;
      left: 16%;
      right: 16%;
      bottom: 0;
      height: 1px;
      pointer-events: none;
      background: linear-gradient(
        90deg,
        transparent 0%,
        rgba(0, 200, 150, 0.7) 50%,
        transparent 100%
      );
      box-shadow: 0 0 14px rgba(0, 200, 150, 0.35);
      z-index: 2;
    }

    .hero-portrait-img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: 50% 18%;
      filter: contrast(1.06) brightness(0.94) saturate(0.92);
      display: block;
    }

    .hero-portrait-fade {
      position: absolute;
      inset: 0;
      pointer-events: none;
      background:
        radial-gradient(ellipse 90% 60% at 50% 110%, rgba(5, 30, 22, 0.85), transparent 65%),
        linear-gradient(180deg, transparent 55%, rgba(5, 30, 22, 0.55) 100%);
    }

    .hero-portrait-grain {
      position: absolute;
      inset: 0;
      pointer-events: none;
      opacity: 0.18;
      mix-blend-mode: overlay;
      background-image:
        radial-gradient(rgba(255, 255, 255, 0.5) 0.5px, transparent 0.6px);
      background-size: 3px 3px;
    }


    .hero-portrait-caption {
      display: flex;
      align-items: center;
      gap: 10px;
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(242, 239, 228, 0.45);
    }
    .hero-portrait-caption-name {
      color: var(--cream);
    }
    .hero-portrait-caption-role {
      color: var(--mint);
    }
    .hero-portrait-caption-sep {
      color: rgba(242, 239, 228, 0.2);
    }

    @media (prefers-reduced-motion: reduce) {
      .hero-portrait-frame {
        box-shadow: 0 20px 50px -20px rgba(0, 0, 0, 0.6);
      }
    }
  </style>
</section>

<div class="divider"></div>
