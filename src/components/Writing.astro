---
import { getCollection, type CollectionEntry } from "astro:content";
import { getT, getLocalePrefix, type Locale } from "~/i18n";

interface Props {
  locale?: Locale;
}
const { locale = "de" } = Astro.props;
const t = getT(locale);
const prefix = getLocalePrefix(locale);

type Post = CollectionEntry<"blog">;
const allPosts = (await getCollection("blog")) as Post[];
const posts: Post[] = allPosts
  .filter((p: Post) => !p.data.draft)
  .sort((a: Post, b: Post) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 4);

const dateFmt = new Intl.DateTimeFormat(t.intlLocale, {
  day: "2-digit",
  month: "short",
  year: "numeric",
});
---

<section id="schreiben" class="relative px-6 md:px-12 py-28 md:py-40">
  <div class="max-w-7xl mx-auto relative">
    <div class="section-intro">
      <div class="reveal-elem">
        <div class="eyebrow mb-8" data-anim="fade-up">{t.writing.eyebrow}</div>
        <h2 class="heading-giant text-cream max-w-2xl" data-anim="section-title">
          {t.writing.headline}
        </h2>
      </div>
      <div class="reveal-elem">
        <p class="font-body text-lg md:text-xl text-cream/80 leading-[1.55] max-w-[58ch]" data-anim="fade-up">
          {t.writing.subline}
        </p>
      </div>
    </div>

    <div class="writing-list reveal-elem mt-14" data-anim-group="tiles">
      {posts.map((post) => (
        <a href={`${prefix}/blog/${post.id}/`} class="writing-item interactive" data-anim="tile">
          <div class="writing-meta">
            <time datetime={post.data.date.toISOString()}>{dateFmt.format(post.data.date)}</time>
            {post.data.readingTime && (
              <>
                <span class="writing-sep" aria-hidden="true">&middot;</span>
                <span>{post.data.readingTime}</span>
              </>
            )}
          </div>
          <h3 class="writing-title">{post.data.title}</h3>
          <p class="writing-excerpt">{post.data.excerpt}</p>
        </a>
      ))}
    </div>

    {posts.length === 0 && (
      <p class="font-body text-cream/55 mt-10">{t.writing.empty}</p>
    )}

    {posts.length > 0 && (
      <div class="reveal-elem mt-14 flex">
        <a href={`${prefix}/blog/`} class="writing-all interactive">
          {t.writing.seeAll}
          <span class="text-mint" aria-hidden="true">&rarr;</span>
        </a>
      </div>
    )}
  </div>
</section>

<style>
  .writing-list {
    display: flex;
    flex-direction: column;
  }
  .writing-item {
    display: block;
    text-decoration: none;
    color: var(--cream);
    padding: 26px 0;
    border-top: 1px solid rgba(242, 239, 228, 0.08);
    transition: padding 0.3s ease;
  }
  .writing-item:last-child {
    border-bottom: 1px solid rgba(242, 239, 228, 0.08);
  }
  .writing-item:hover {
    padding-left: 8px;
  }
  .writing-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: rgba(242, 239, 228, 0.4);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 8px;
  }
  .writing-sep {
    color: rgba(242, 239, 228, 0.2);
  }
  .writing-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(18px, 2.2vw, 22px);
    color: var(--cream);
    letter-spacing: -0.012em;
    line-height: 1.28;
    margin-bottom: 6px;
    transition: color 0.25s ease;
  }
  .writing-item:hover .writing-title {
    color: var(--mint);
  }
  .writing-excerpt {
    font-family: var(--font-body);
    font-size: 14.5px;
    color: rgba(242, 239, 228, 0.6);
    line-height: 1.55;
    max-width: 70ch;
  }

  .writing-all {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 11px 22px;
    border: 1px solid rgba(0, 200, 150, 0.4);
    border-radius: 999px;
    background: rgba(0, 200, 150, 0.08);
    color: var(--mint);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background 0.25s ease, border-color 0.25s ease;
  }
  .writing-all:hover {
    background: rgba(0, 200, 150, 0.18);
    border-color: var(--mint);
  }
</style>

<div class="divider"></div>
