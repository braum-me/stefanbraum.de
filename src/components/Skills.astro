---
import { skills, skillDomains, type SkillDomain } from "~/data/skills.ts";
import { certifications } from "~/data/certifications.ts";
import { cases } from "~/data/cases.ts";
import { getT, type Locale } from "~/i18n";

interface Props {
  locale?: Locale;
}
const { locale = "de" } = Astro.props;
const t = getT(locale);

// Group skills by domain for mobile / fallback grid - localized labels
const groupedSkills = (Object.keys(skillDomains) as SkillDomain[]).map((d) => ({
  id: d,
  label: t.skills.domains[d],
  items: skills.filter((s) => s.domain === d),
}));

// Pre-resolve project + certificate refs server-side for each skill.
// Cap auf 6 neueste Projekte (cases ist chronologisch desc sortiert) + 1 Cert
// damit das Panel nicht zu lang wird, ohne dass Pagination noetig ist.
const MAX_PROJECTS = 6;
const MAX_CERTS = 1;

const skillDetails = skills.map((s) => {
  const allProjects = s.projects
    .map((pid) => cases.find((c) => c.id === pid))
    .filter((c): c is NonNullable<typeof c> => c !== undefined)
    .sort((a, b) => cases.indexOf(a) - cases.indexOf(b));
  const allCerts = s.certificates
    .map((cid) => certifications.find((c) => c.id === cid))
    .filter((c): c is NonNullable<typeof c> => c !== undefined);
  return {
    ...s,
    projectRefs: allProjects.slice(0, MAX_PROJECTS),
    moreProjects: Math.max(0, allProjects.length - MAX_PROJECTS),
    certificateRefs: allCerts.slice(0, MAX_CERTS),
  };
});
---

<section id="skills" class="relative px-6 md:px-12 py-28 md:py-40">
  <div class="max-w-7xl mx-auto relative">
    <div class="section-intro">
      <div class="reveal-elem">
        <div class="eyebrow mb-8">{t.skills.eyebrow}</div>
        <h2 class="heading-giant text-cream max-w-2xl" data-anim="section-title">{t.skills.headline}</h2>
      </div>
      <div class="reveal-elem">
        <p class="font-body text-lg md:text-xl text-cream/80 leading-[1.55] max-w-[58ch]">
          {t.skills.subline}
        </p>
      </div>
    </div>

    <div class="grid lg:grid-cols-[1.5fr_1fr] gap-10 lg:gap-16 items-start mt-14 md:mt-20 reveal-elem">
      <!-- Left: rotating sphere (desktop) / static grouped grid (mobile / reduced motion) -->
      <div class="skills-sphere-wrap">
        <div class="skills-sphere" id="skills-sphere" aria-label={t.skills.sphereAria}>
          {skills.map((s) => (
            <button
              type="button"
              class="skill-tag"
              data-skill-id={s.id}
              data-name={s.name}
              data-domain={s.domain}
              aria-pressed="false"
              aria-label={`${s.name} - ${t.skills.skillDetailLabel}`}
            >
              {s.name}
            </button>
          ))}
        </div>
        <div class="skills-grid-fallback">
          {groupedSkills.map((g) => (
            <div class="skill-group">
              <div class="skill-group-head">{g.label}</div>
              <div class="skill-group-items">
                {g.items.map((s) => (
                  <button
                    type="button"
                    class="skill-tag-static"
                    data-skill-id={s.id}
                    data-domain={s.domain}
                    aria-pressed="false"
                    aria-label={`${s.name} - ${t.skills.skillDetailLabel}`}
                  >
                    {s.name}
                  </button>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: dynamic detail panel -->
      <aside class="skill-panel" id="skill-panel" data-active="">
        <!-- Default state: certificates list (no pagination, fits all 6) -->
        <div class="panel-state is-active" data-state="default">
          <div class="kicker text-cream/55 mb-5">{t.skills.certificates}</div>
          <ul class="certs-list">
            {certifications.map((c) => (
              <li class="cert-item">
                <span class="cert-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 3 L4 7 V13 C4 17 8 20 12 21 C16 20 20 17 20 13 V7 Z" />
                    <path d="M9 12 L11 14 L15 10" />
                  </svg>
                </span>
                <div class="cert-body">
                  <div class="cert-name">{c.name}</div>
                  <div class="cert-meta">
                    <span>{c.issuer}</span>
                    <span class="cert-meta-sep" aria-hidden="true">·</span>
                    <span>{c.year}</span>
                  </div>
                </div>
              </li>
            ))}
          </ul>
          <p class="panel-footer-hint">
            {t.skills.panelHint}
          </p>
        </div>

        <!-- One panel-state per skill, populated server-side -->
        {skillDetails.map((s) => (
          <div class="panel-state" data-state="skill" data-skill-id={s.id}>
            <button type="button" class="panel-back interactive" aria-label={t.skills.backAria}>
              <span aria-hidden="true">&larr;</span>
              <span>{t.skills.backLabel}</span>
            </button>
            <div class="kicker text-mint mb-3">{t.skills.activeLabel}</div>
            <h3 class="skill-detail-name">{s.name}</h3>
            <div class="skill-detail-meta">
              <span class="skill-detail-years">{s.yearsExperience}+ {t.skills.yearsSuffix}</span>
              <span class="skill-detail-sep" aria-hidden="true">&middot;</span>
              <span class="skill-detail-subs">{s.subSkills.join(" - ")}</span>
            </div>

            {(s.projectRefs.length > 0 || s.certificateRefs.length > 0) ? (
              <>
                <div class="kicker text-cream/55 mt-7 mb-4">{t.skills.proofLabel}</div>
                <ul class="proof-list">
                  {s.projectRefs.map((p) => (
                    <li>
                      <button
                        type="button"
                        class="proof-item interactive"
                        data-target-case={p.id}
                        aria-label={p.title}
                      >
                        <span class="proof-badge proof-badge-proj">{t.skills.proofProj}</span>
                        <span class="proof-text">
                          <span class="proof-title">{p.title}</span>
                          <span class="proof-sub">{p.period}</span>
                        </span>
                      </button>
                    </li>
                  ))}
                  {s.certificateRefs.map((c) => (
                    <li>
                      <div class="proof-item proof-item-static">
                        <span class="proof-badge proof-badge-cert">{t.skills.proofCert}</span>
                        <span class="proof-text">
                          <span class="proof-title">{c.name}</span>
                          <span class="proof-sub">{c.issuer} - {c.year}</span>
                        </span>
                      </div>
                    </li>
                  ))}
                </ul>
                {s.moreProjects > 0 && (
                  <p class="proof-more">+ {s.moreProjects} weitere Projekte im Portfolio.</p>
                )}
              </>
            ) : (
              <p class="proof-empty">{t.skills.handsOn}</p>
            )}

            <p class="panel-footer-hint">
              {t.skills.panelHint}
            </p>
          </div>
        ))}
      </aside>
    </div>
  </div>
</section>

<style>
  /* Wrap */
  .skills-sphere-wrap {
    position: relative;
    width: 100%;
  }

  /* Desktop sphere */
  .skills-sphere {
    position: relative;
    aspect-ratio: 1 / 1;
    max-width: 580px;
    margin: 0 auto;
    cursor: grab;
    touch-action: none;
  }
  .skills-sphere:active {
    cursor: grabbing;
  }

  .skill-tag {
    position: absolute;
    top: 50%;
    left: 50%;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 14px;
    color: var(--cream);
    letter-spacing: -0.01em;
    line-height: 1;
    white-space: nowrap;
    transform-origin: center;
    will-change: transform, opacity;
    padding: 5px 12px;
    border-radius: 4px;
    background: transparent;
    border: 1px solid transparent;
    cursor: pointer;
    transition:
      color 0.2s ease,
      background 0.2s ease,
      border-color 0.2s ease;
    user-select: none;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  /* Domain color accents (default state) */
  .skill-tag[data-domain="cloud"] { color: rgba(140, 200, 255, 0.85); }
  .skill-tag[data-domain="enterprise"] { color: rgba(242, 239, 228, 0.92); }
  .skill-tag[data-domain="modernwork"] { color: rgba(180, 220, 200, 0.85); }
  .skill-tag[data-domain="security"] { color: rgba(255, 200, 130, 0.82); }
  /* AI-Akzentfarbe entfernt - alle Domänen gleich gewichtet */
  .skill-tag[data-domain="method"] { color: rgba(220, 220, 220, 0.78); }
  .skill-tag[data-domain="leadership"] { color: rgba(255, 180, 150, 0.85); }

  /* Hover state - any domain */
  .skill-tag.is-hovered {
    color: var(--mint) !important;
    background: rgba(0, 200, 150, 0.1);
    border-color: rgba(0, 200, 150, 0.45);
  }

  /* Clicked / persistent active state */
  .skill-tag.is-clicked {
    color: var(--mint) !important;
    background: rgba(0, 200, 150, 0.16);
    border-color: var(--mint);
    box-shadow: 0 0 16px rgba(0, 200, 150, 0.35);
  }
  .skill-tag.is-clicked::before {
    content: "";
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--mint);
    box-shadow: 0 0 6px rgba(0, 200, 150, 0.7);
    flex-shrink: 0;
  }

  /* Mobile / static grid */
  .skills-grid-fallback {
    display: none;
  }
  .skill-group {
    margin-bottom: 24px;
  }
  .skill-group-head {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--mint);
    margin-bottom: 12px;
  }
  .skill-group-items {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .skill-tag-static {
    padding: 6px 12px;
    border: 1px solid rgba(242, 239, 228, 0.15);
    border-radius: 4px;
    background: rgba(5, 30, 22, 0.4);
    color: var(--cream);
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 13.5px;
    cursor: pointer;
    transition:
      border-color 0.25s ease,
      background 0.25s ease,
      color 0.25s ease;
  }
  .skill-tag-static:hover,
  .skill-tag-static.is-clicked {
    border-color: var(--mint);
    color: var(--mint);
    background: rgba(0, 200, 150, 0.1);
  }

  @media (max-width: 900px) {
    .skills-sphere {
      display: none;
    }
    .skills-grid-fallback {
      display: block;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .skills-sphere {
      display: none;
    }
    .skills-grid-fallback {
      display: block;
    }
  }

  /* Skill panel - aktiver state bestimmt Hoehe, inaktive sind absolute
     gestapelt und beeinflussen das Layout nicht. So passt sich der
     Mint-Border exakt an den aktuellen Inhalt an. */
  .skill-panel {
    position: relative;
    border-left: 2px solid var(--mint);
    padding-left: 28px;
  }
  @media (max-width: 1023px) {
    .skill-panel {
      border-left: 0;
      border-top: 2px solid var(--mint);
      padding-left: 0;
      padding-top: 28px;
      margin-top: 32px;
    }
  }

  /* Hint, dass es mehr Projekte gibt als angezeigt (Cap auf 6) */
  .proof-more {
    margin-top: 14px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    color: rgba(242, 239, 228, 0.45);
  }

  .panel-state {
    position: absolute;
    top: 0;
    left: 28px;
    right: 0;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.28s ease;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  @media (max-width: 1023px) {
    .panel-state {
      top: 28px;
      left: 0;
    }
  }
  .panel-state.is-active {
    position: relative;
    top: auto;
    left: auto;
    right: auto;
    opacity: 1;
    pointer-events: auto;
  }
  @media (max-width: 1023px) {
    .panel-state.is-active {
      top: auto;
      left: auto;
    }
  }

  /* Default panel - certifications list */
  .certs-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .cert-item {
    display: flex;
    gap: 14px;
    align-items: flex-start;
    padding: 14px 16px;
    border: 1px solid rgba(242, 239, 228, 0.08);
    border-radius: 6px;
    background: rgba(5, 30, 22, 0.3);
    transition: border-color 0.25s ease, background 0.25s ease;
  }
  .cert-item:hover {
    border-color: rgba(0, 200, 150, 0.4);
    background: rgba(13, 61, 46, 0.4);
  }
  .cert-icon {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    color: var(--mint);
    margin-top: 1px;
  }
  .cert-icon svg { width: 100%; height: 100%; }
  .cert-body { min-width: 0; flex: 1; }
  .cert-name {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 14.5px;
    color: var(--cream);
    line-height: 1.3;
    letter-spacing: -0.01em;
  }
  .cert-meta {
    margin-top: 4px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    color: rgba(242, 239, 228, 0.5);
  }
  .cert-meta-sep { color: rgba(242, 239, 228, 0.25); }

  /* Active skill panel */
  .panel-back {
    align-self: flex-start;
    display: none;
    align-items: center;
    gap: 8px;
    margin-bottom: 20px;
    padding: 6px 12px;
    background: transparent;
    border: 1px solid rgba(242, 239, 228, 0.15);
    border-radius: 4px;
    color: var(--cream);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    transition: border-color 0.25s ease, color 0.25s ease;
  }
  .panel-back:hover {
    border-color: var(--mint);
    color: var(--mint);
  }
  @media (max-width: 1023px) {
    .panel-back {
      display: inline-flex;
    }
  }

  .skill-detail-name {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.6rem, 2.4vw, 2rem);
    color: var(--cream);
    letter-spacing: -0.018em;
    line-height: 1.15;
    margin-bottom: 12px;
  }
  .skill-detail-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 10px;
    margin-bottom: 8px;
  }
  .skill-detail-years {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.5rem, 2.2vw, 1.85rem);
    color: var(--mint);
    line-height: 1;
    letter-spacing: -0.02em;
    font-variant-numeric: tabular-nums;
  }
  .skill-detail-sep {
    color: rgba(242, 239, 228, 0.2);
    font-family: var(--font-mono);
    font-size: 14px;
  }
  .skill-detail-subs {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    color: rgba(242, 239, 228, 0.65);
    text-transform: uppercase;
    line-height: 1.5;
  }

  .proof-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .proof-item {
    width: 100%;
    display: flex;
    gap: 12px;
    align-items: flex-start;
    padding: 12px 14px;
    background: rgba(5, 30, 22, 0.35);
    border: 1px solid rgba(242, 239, 228, 0.08);
    border-radius: 5px;
    text-align: left;
    cursor: pointer;
    transition:
      border-color 0.25s ease,
      background 0.25s ease,
      transform 0.25s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .proof-item-static {
    cursor: default;
  }
  .proof-item:not(.proof-item-static):hover {
    border-color: rgba(0, 200, 150, 0.5);
    background: rgba(13, 61, 46, 0.45);
    transform: translateX(2px);
  }
  .proof-badge {
    flex-shrink: 0;
    padding: 3px 7px;
    border-radius: 3px;
    font-family: var(--font-mono);
    font-size: 9.5px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    line-height: 1.4;
    margin-top: 1px;
  }
  .proof-badge-proj {
    background: rgba(0, 200, 150, 0.15);
    color: var(--mint);
    border: 1px solid rgba(0, 200, 150, 0.35);
  }
  .proof-badge-cert {
    background: transparent;
    color: rgba(242, 239, 228, 0.7);
    border: 1px solid rgba(242, 239, 228, 0.2);
  }
  .proof-text {
    display: flex;
    flex-direction: column;
    gap: 3px;
    min-width: 0;
    flex: 1;
  }
  .proof-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 14px;
    color: var(--cream);
    line-height: 1.3;
    letter-spacing: -0.005em;
  }
  .proof-sub {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.05em;
    color: rgba(242, 239, 228, 0.5);
  }

  .proof-empty {
    margin-top: 16px;
    padding: 14px 16px;
    background: rgba(5, 30, 22, 0.3);
    border: 1px dashed rgba(242, 239, 228, 0.15);
    border-radius: 5px;
    font-family: var(--font-body);
    font-size: 13px;
    color: rgba(242, 239, 228, 0.55);
    font-style: italic;
  }

  .panel-footer-hint {
    margin-top: 24px;
    padding-top: 24px;
    border-top: 1px solid rgba(242, 239, 228, 0.05);
    font-family: var(--font-body);
    font-size: 12.5px;
    color: rgba(242, 239, 228, 0.4);
    line-height: 1.5;
    max-width: 38ch;
  }
</style>

<div class="divider"></div>

<script>
  const sphere = document.getElementById("skills-sphere");
  const panel = document.getElementById("skill-panel") as HTMLElement | null;
  const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const isSmall = window.matchMedia("(max-width: 900px)").matches;

  const tags = Array.from(document.querySelectorAll<HTMLButtonElement>(".skill-tag"));
  const tagsStatic = Array.from(document.querySelectorAll<HTMLButtonElement>(".skill-tag-static"));
  const allTagButtons = [...tags, ...tagsStatic];
  const panels = Array.from(document.querySelectorAll<HTMLElement>(".panel-state"));
  const backButtons = Array.from(document.querySelectorAll<HTMLButtonElement>(".panel-back"));

  // State
  let clicked: string | null = null;
  let hovered: string | null = null;
  let hoverTimer: number | null = null;

  // Render-state into DOM
  // Lock-Logik: clicked > hovered. Bei aktivem Lock überschreibt Hover NICHT
  // mehr das Panel.
  const renderPanel = () => {
    const effective = clicked ?? hovered;
    panels.forEach((p) => {
      const id = p.dataset.skillId ?? "";
      const isDefault = p.dataset.state === "default";
      const shouldShow =
        (effective === null && isDefault) ||
        (effective !== null && id === effective);
      p.classList.toggle("is-active", shouldShow);
    });
    if (panel) panel.dataset.active = effective ?? "";
  };

  const renderTagStates = () => {
    allTagButtons.forEach((t) => {
      const id = t.dataset.skillId;
      const isClicked = id === clicked && id !== undefined;
      const isHovered = id === hovered && id !== clicked && id !== undefined;
      t.classList.toggle("is-clicked", isClicked);
      t.classList.toggle("is-hovered", isHovered);
      t.setAttribute("aria-pressed", String(isClicked));
    });
  };

  const setHovered = (id: string | null) => {
    if (hovered === id) return;
    hovered = id;
    renderTagStates();
    renderPanel();
  };

  const setClicked = (id: string | null) => {
    clicked = id;
    renderTagStates();
    renderPanel();
  };

  // Hover handlers (debounced 150ms)
  const onTagEnter = (id: string) => {
    if (hoverTimer) window.clearTimeout(hoverTimer);
    hoverTimer = window.setTimeout(() => setHovered(id), 150);
  };
  const onTagLeave = () => {
    if (hoverTimer) window.clearTimeout(hoverTimer);
    hoverTimer = window.setTimeout(() => setHovered(null), 150);
  };

  // Click handlers
  const onTagClick = (id: string) => {
    if (clicked === id) {
      setClicked(null);
    } else {
      setClicked(id);
    }
  };

  // Wire up sphere tags - Hover preview + Click to lock
  tags.forEach((tag) => {
    const id = tag.dataset.skillId;
    if (!id) return;
    tag.addEventListener("mouseenter", () => onTagEnter(id));
    tag.addEventListener("mouseleave", onTagLeave);
    tag.addEventListener("click", (e) => {
      e.stopPropagation();
      onTagClick(id);
    });
  });

  // Static fallback tags (mobile / reduced motion): only click, no hover
  tagsStatic.forEach((tag) => {
    const id = tag.dataset.skillId;
    if (!id) return;
    tag.addEventListener("click", (e) => {
      e.stopPropagation();
      onTagClick(id);
    });
  });

  // Click outside the skills section: release lock + sphere resumes spinning.
  // Clicks innerhalb von #skills (Pagination, Proof-Items, Panel) bleiben aktiv.
  document.addEventListener("click", (e) => {
    if (clicked === null) return;
    const skillsSection = document.getElementById("skills");
    if (!skillsSection) return;
    if (skillsSection.contains(e.target as Node)) return;
    setClicked(null);
  });

  // Back buttons in active panels (mobile)
  backButtons.forEach((b) => {
    b.addEventListener("click", () => setClicked(null));
  });


  // Proof item click → delegate to Cases.astro via case:focus event.
  // Cases.astro will reset filter, navigate to correct page, open + scroll.
  document.querySelectorAll<HTMLButtonElement>(".proof-item[data-target-case]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const caseId = btn.dataset.targetCase;
      if (!caseId) return;
      document.dispatchEvent(
        new CustomEvent("case:focus", { detail: { id: caseId } }),
      );
    });
  });

  // Sphere only when not small + not reduced-motion
  if (sphere && !isSmall && !prefersReduced) {
    const n = tags.length;
    const phi = Math.PI * (3 - Math.sqrt(5));
    const basePos = tags.map((_, i) => {
      const y = 1 - (i / Math.max(1, n - 1)) * 2;
      const r = Math.sqrt(Math.max(0, 1 - y * y));
      const th = phi * i;
      return { x: Math.cos(th) * r, y, z: Math.sin(th) * r };
    });

    let rotX = 0.3;
    let rotY = 0;
    let targetRotX = 0.3;
    let targetRotY = 0;
    let lastPX = 0;
    let lastPY = 0;
    let dragging = false;
    let resumeTimer: number | null = null;
    let pdownX = 0;
    let pdownY = 0;

    const updateSize = () => {
      const rect = sphere.getBoundingClientRect();
      return { radius: Math.min(rect.width, rect.height) * 0.42 };
    };
    let dims = updateSize();
    window.addEventListener("resize", () => { dims = updateSize(); });

    // Pause auto-rotation while hovering over a skill-tag, dragging,
    // or with a clicked detail view open
    const isAutoSpin = () => !dragging && clicked === null && hovered === null;

    let rafId: number | null = null;
    let isVisible = false;

    const render = () => {
      if (isAutoSpin()) {
        targetRotY += 0.0025;
      }
      rotX += (targetRotX - rotX) * 0.08;
      rotY += (targetRotY - rotY) * 0.08;

      const cosX = Math.cos(rotX);
      const sinX = Math.sin(rotX);
      const cosY = Math.cos(rotY);
      const sinY = Math.sin(rotY);

      tags.forEach((tag, i) => {
        const p = basePos[i];
        if (!p) return;
        const x1 = p.x * cosY + p.z * sinY;
        const z1 = -p.x * sinY + p.z * cosY;
        const y2 = p.y * cosX - z1 * sinX;
        const z2 = p.y * sinX + z1 * cosX;

        const screenX = x1 * dims.radius;
        const screenY = y2 * dims.radius;
        const depth = (z2 + 1) / 2;
        const scale = 0.55 + depth * 0.55;
        const opacity = 0.32 + depth * 0.68;
        const zIndex = Math.round(depth * 100);

        tag.style.transform = `translate(-50%, -50%) translate(${screenX}px, ${screenY}px) scale(${scale})`;
        tag.style.opacity = String(opacity);
        tag.style.zIndex = String(zIndex);
      });

      if (isVisible) {
        rafId = requestAnimationFrame(render);
      } else {
        rafId = null;
      }
    };

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting && !rafId) {
            isVisible = true;
            rafId = requestAnimationFrame(render);
          } else if (!e.isIntersecting) {
            isVisible = false;
          }
        });
      },
      { rootMargin: "100px 0px" },
    );
    io.observe(sphere);

    // Drag interaction
    sphere.addEventListener("pointerdown", (e) => {
      dragging = true;
      pdownX = e.clientX;
      pdownY = e.clientY;
      lastPX = e.clientX;
      lastPY = e.clientY;
      sphere.setPointerCapture(e.pointerId);
      if (resumeTimer) {
        window.clearTimeout(resumeTimer);
        resumeTimer = null;
      }
    });
    sphere.addEventListener("pointermove", (e) => {
      if (!dragging) return;
      const dx = e.clientX - lastPX;
      const dy = e.clientY - lastPY;
      targetRotY += dx * 0.008;
      targetRotX += dy * 0.008;
      targetRotX = Math.max(-1.2, Math.min(1.2, targetRotX));
      lastPX = e.clientX;
      lastPY = e.clientY;
    });
    const endDrag = () => {
      if (!dragging) return;
      dragging = false;
    };
    sphere.addEventListener("pointerup", endDrag);
    sphere.addEventListener("pointercancel", endDrag);

    // Sphere tag click - distinguish from drag
    tags.forEach((tag) => {
      tag.addEventListener("click", (e) => {
        const dx = Math.abs(e.clientX - pdownX);
        const dy = Math.abs(e.clientY - pdownY);
        if (dx < 4 && dy < 4) {
          const id = tag.dataset.skillId;
          if (id) onTagClick(id);
        }
      });
    });
  }

  // Initial render
  renderPanel();
  renderTagStates();
</script>
